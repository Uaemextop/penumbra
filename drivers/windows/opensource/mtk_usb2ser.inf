; ==========================================================================
;  Source disk layout
; ==========================================================================
[SourceDisksFiles]
mtk_usb2ser.sys = 1

[SourceDisksNames]
1 = %DiskName%

; ==========================================================================
;  Install section
; ==========================================================================
[MTK_Install.NT]
CopyFiles = MTK_CopyFiles
AddReg    = MTK_AddReg

[MTK_Install.NTamd64]
CopyFiles = MTK_CopyFiles
AddReg    = MTK_AddReg

[MTK_Install.NTx86]
CopyFiles = MTK_CopyFiles
AddReg    = MTK_AddReg

; ==========================================================================
;  Service definition — KMDF driver
; ==========================================================================
[MTK_Install.NT.Services]
AddService = mtk_usb2ser, 2, MTK_Service

[MTK_Install.NTamd64.Services]
AddService = mtk_usb2ser, 2, MTK_Service

[MTK_Install.NTx86.Services]
AddService = mtk_usb2ser, 2, MTK_Service

[MTK_Service]
DisplayName   = %ServiceDesc%
ServiceType   = 1                       ; SERVICE_KERNEL_DRIVER
StartType     = 3                       ; SERVICE_DEMAND_START
ErrorControl  = 1                       ; SERVICE_ERROR_NORMAL
ServiceBinary = %13%\mtk_usb2ser.sys

; ==========================================================================
;  KMDF Co-Installer / WDF Section
; ==========================================================================
[MTK_Install.NT.Wdf]
KmdfService = mtk_usb2ser, MTK_WdfSection

[MTK_Install.NTamd64.Wdf]
KmdfService = mtk_usb2ser, MTK_WdfSection

[MTK_Install.NTx86.Wdf]
KmdfService = mtk_usb2ser, MTK_WdfSection

[MTK_WdfSection]
KmdfLibraryVersion = 1.33

; ==========================================================================
;  Hardware registry settings
; ==========================================================================
[MTK_Install.NT.HW]
AddReg = MTK_HwAddReg

[MTK_Install.NTamd64.HW]
AddReg = MTK_HwAddReg

[MTK_Install.NTx86.HW]
AddReg = MTK_HwAddReg

[MTK_HwAddReg]
HKR,,DriverInfo,,"MediaTek USB CDC ACM Serial Port (KMDF)"
HKR,,Security,,"D:P(A;;GA;;;SY)(A;;GRGWGX;;;BA)(A;;GRGWGX;;;WD)(A;;GRGWGX;;;RC)"

; ==========================================================================
;  Driver copy and registry
; ==========================================================================
[MTK_CopyFiles]
mtk_usb2ser.sys

[MTK_AddReg]
HKR,,NTMPDriver,,mtk_usb2ser.sys
HKR,,Installer32,,"MsPorts.Dll,PortsClassInstaller"
HKR,,EnumPropPages32,,"MsPorts.dll,SerialPortPropPageProvider"
HKR,,IdleTime,0x00010001,10
HKR,,IdleEnable,0x00010001,0
HKR,,IdleWWBinded,0x00010001,1

; ==========================================================================
;  Strings
; ==========================================================================
[Strings]
ProviderName  = "Penumbra — MTK Loader Drivers Opensource"
DiskName      = "MediaTek USB CDC ACM Driver Disk"
ServiceDesc   = "MediaTek USB CDC ACM Serial Port Driver (KMDF)"
MTK_BOOTROM   = "MediaTek USB Port (BROM)"
MTK_PRELOADER = "MediaTek PreLoader USB VCOM Port"
MTK_DA        = "MediaTek DA USB VCOM Port"
MTK_VCOM      = "MediaTek USB VCOM Port"
MTK_MODEM     = "MediaTek Modem Port"
MTK_ELT       = "MediaTek ELT Port"
MTK_ETS       = "MediaTek ETS Port"
MTK_AT        = "MediaTek AT Command Port"
