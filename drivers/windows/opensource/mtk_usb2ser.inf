;
; mtk_usb2ser.inf
;
; KMDF driver INF for MediaTek USB CDC ACM serial port devices.
; Open-source reimplementation of the proprietary usb2ser.sys driver.
;
; Modified for Penumbra compatibility.
;
; Contains ALL MediaTek hardware IDs from the original cdc-acm.inf.
; Service name: mtk_usb2ser
; Uses our compiled mtk_usb2ser.sys with KMDF co-installer.
;
; SPDX-License-Identifier: MIT
;

[Version]
Signature   = "$Windows NT$"
Class       = Ports
ClassGuid   = {4D36E978-E325-11CE-BFC1-08002BE10318}
Provider    = %ProviderName%
DriverVer   = 03/13/2026,2.0.0.0
CatalogFile = mtk_usb2ser.cat
PnpLockdown = 1

[Manufacturer]
%ProviderName% = DeviceList, NTamd64, NTx86

[DestinationDirs]
DefaultDestDir      = 13

